+/* Look up KA parameters for an RMBlast custom matrix by name only.
+ * Unlike Blast_KarlinBlkGappedCalc, gap_open and gap_extend are ignored so
+ * that ALP-computed parameters (stored once per matrix) are used regardless
+ * of the gap costs specified at the command line. -RMH- */
+Int2
+Blast_KarlinBlkRMBlastTableLookup(Blast_KarlinBlk* kbp, const char* matrix_name)
+{
+   array_of_8 *values;
+   MatrixInfo* matrix_info;
+   ListNode* vnp, *head;
+   Int2 status = 1; /* default: matrix not found */
+   int i;
+
+   if (matrix_name == NULL) return -1;
+
+   vnp = head = BlastLoadMatrixValues(FALSE);
+   while (vnp) {
+       matrix_info = vnp->ptr;
+       if (strcasecmp(matrix_info->name, matrix_name) == 0 &&
+           matrix_info->max_number_values > 0) {
+           values = matrix_info->values;
+           /* Use the first row that is not the ungapped (INT2_MAX) row. */
+           for (i = 0; i < matrix_info->max_number_values; i++) {
+               if (BLAST_Nint(values[i][0]) != INT2_MAX) {
+                   if (kbp) {
+                       kbp->Lambda = values[i][3];
+                       kbp->K      = values[i][4];
+                       kbp->logK   = log(kbp->K);
+                       kbp->H      = values[i][5];
+                   }
+                   status = 0;
+                   break;
+               }
+           }
+           break;
+       }
+       vnp = vnp->next;
+   }
+   BlastMatrixValuesDestruct(head);
+   return status;
+}
