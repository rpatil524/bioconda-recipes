+
+// Per-subject masklevel filtering for rmblastn. -RMH-
+// Applies masklevel independently within a single HSPList (one subject).
+// Must be called after traceback so that gapped scores are used.
+Int2 Blast_HSPListApplyMasklevel(BlastHSPList *hsplist,
+                                  const BlastQueryInfo *query_info,
+                                  Int4 masklevel, Int4 query_length)
+{
+   Int4 j;
+   Int4 hsp_count;
+   SHspWrap *hsp_array;
+   BlastIntervalTree *tree;
+
+   if (!hsplist || hsplist->hspcnt < 2)
+      return 0;
+
+   hsp_count = hsplist->hspcnt;
+   tree = Blast_IntervalTreeInit(0, query_length + 1, 0, 0);
+   hsp_array = (SHspWrap *)malloc(hsp_count * sizeof(SHspWrap));
+
+   for (j = 0; j < hsp_count; j++) {
+      hsp_array[j].hsplist = hsplist;
+      hsp_array[j].hsp = hsplist->hsp_array[j];
+   }
+   hsplist->hspcnt = 0;
+
+   qsort(hsp_array, hsp_count, sizeof(SHspWrap), s_SortHspWrapRawScore);
+   Blast_IntervalTreeReset(tree);
+
+   for (j = 0; j < hsp_count; j++) {
+      BlastHSP *hsp = hsp_array[j].hsp;
+      if (BlastIntervalTreeMasksHSP(tree, hsp, query_info, 0, masklevel)) {
+         Blast_HSPFree(hsp);
+      } else {
+         BlastIntervalTreeAddHSP(hsp, tree, query_info,
+                                 eQueryOnlyStrandIndifferent);
+         Blast_HSPListSaveHSP(hsplist, hsp);
+         if (hsplist->hspcnt == 1)
+            hsplist->best_evalue = hsp->evalue;
+      }
+   }
+   sfree(hsp_array);
+   Blast_HSPListSortByScore(hsplist);
+   tree = Blast_IntervalTreeFree(tree);
+   return 0;
+}
 
